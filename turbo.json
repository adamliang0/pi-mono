{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "package.json", "tsconfig.json", "tsconfig.build.json"],
      "outputs": ["dist/**", "build/**"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:tsc": {
      "cache": false,
      "persistent": true
    },
    "check": {
      "dependsOn": ["build"],
      "inputs": ["src/**", "test/**", "package.json", "tsconfig.json"],
      "outputs": [],
      "cache": true
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["test/**", "src/**", "package.json"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "clean": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["build"],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["build"],
      "cache": true
    }
  }
}
