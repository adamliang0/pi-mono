{
    "name": "pi-monorepo",
    "private": true,
    "type": "module",
    "workspaces": [
        "packages/*",
        "packages/web-ui/example"
    ],
    "scripts": {
        "clean": "shx rm -rf packages/*/dist packages/web-ui/example/dist",
        "build": "turbo build && bun scripts/compile-pi-to-bin.mjs",
        "build:ts": "tsgo -b tsconfig.build.json",
        "dev": "turbo dev",
        "dev:tsc": "turbo dev:tsc",
        "check": "biome check --write --error-on-warnings . && tsgo --noEmit && bun run check:browser-smoke && cd packages/web-ui && bun run check",
        "check:browser-smoke": "bun scripts/check-browser-smoke.mjs",
        "test": "turbo test",
        "prepublishOnly": "bun run clean && bun run build && bun run check",
        "prepare": "husky"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.10",
        "@types/node": "^25.5.2",
        "@typescript/native-preview": "7.0.0-dev.20260404.1",
        "concurrently": "^9.2.1",
        "esbuild": "^0.28.0",
        "husky": "^9.1.7",
        "shx": "^0.4.0",
        "tsx": "^4.21.0",
        "turbo": "^2.9.3",
        "typescript": "^6.0.2"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "packageManager": "bun@1.3.11",
    "dependencies": {
        "@mariozechner/jiti": "^2.6.5",
        "@mariozechner/pi-coding-agent": "workspace:*",
        "get-east-asian-width": "^1.5.0"
    }
}
