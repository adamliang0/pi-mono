#!/bin/sh
set -e

echo "Running formatting, linting, and type checking..."
bun run check

# Only run browser smoke if relevant files changed
if git diff --cached --name-only | grep -qE '^(packages/ai/|packages/web-ui/|package\.json)\b'; then
  echo "Running browser smoke check..."
  bun run check:browser-smoke
fi

# Re-stage formatted files
git diff --cached --name-only | xargs -r git add

echo "✅ All pre-commit checks passed!"
